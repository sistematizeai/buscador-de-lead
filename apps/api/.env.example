DATABASE_URL=
DIRECT_URL=
JWT_SECRET=
ENABLE_SWAGGER=false
PASSWORD_RESET_DEV_RESPONSE=false

# Frontend allowed to call this API.
NEXT_PUBLIC_APP_URL=https://seu-projeto.vercel.app
NEXT_PUBLIC_API_URL=https://buscador-lead-api.onrender.com/api
CORS_ALLOWED_ORIGINS=https://seu-projeto.vercel.app
# Optional, only if you intentionally want to allow a controlled preview domain suffix.
# CORS_ALLOWED_HOST_SUFFIXES=buscador-lead.vercel.app

# AI provider. For OpenRouter use OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=1000

# Individual company search.
COMPANY_CNPJ_PROVIDER_URL=https://brasilapi.com.br/api/cnpj/v1
COMPANY_SEARCH_TIMEOUT_MS=8000

# Scraper
SCRAPER_PROVIDER=gosom
GOSOM_BINARY_PATH=tools/bin/gosom-google-maps-scraper
GOSOM_TIMEOUT_MS=120000
GOSOM_DEPTH=1
SCRAPER_QUERY_RETRIES=2
SCRAPER_MAX_ROUNDS=6
SCRAPER_ALLOW_MOCK_FALLBACK=false
# Optional backend-only search API for social sources. Improves Instagram/Marketplace reliability.
BRAVE_SEARCH_API_KEY=

# Instagram enrichment after each business lead is found.
# Keep enabled to search the Instagram profile one by one for each store.
INSTAGRAM_LOOKUP_ENABLED=true
INSTAGRAM_LOOKUP_MAX_PER_CAMPAIGN=100

# Optional local/diagnostic settings.
PORT=3001
DB_HEALTH_RETRIES=5
DB_HEALTH_RETRY_DELAY_MS=2500
