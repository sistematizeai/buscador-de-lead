DATABASE_URL=
DIRECT_URL=
JWT_SECRET=

# Frontend allowed to call this API.
NEXT_PUBLIC_APP_URL=https://seu-projeto.vercel.app
CORS_ALLOWED_ORIGINS=https://seu-projeto.vercel.app
# Optional, only if you intentionally want to allow a controlled preview domain suffix.
# CORS_ALLOWED_HOST_SUFFIXES=buscador-lead.vercel.app

# AI provider. For OpenRouter use OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# Scraper
SCRAPER_PROVIDER=gosom
GOSOM_BINARY_PATH=tools/bin/gosom-google-maps-scraper
GOSOM_TIMEOUT_MS=120000
GOSOM_DEPTH=1
SCRAPER_QUERY_RETRIES=2
SCRAPER_MAX_ROUNDS=6
SCRAPER_ALLOW_MOCK_FALLBACK=false
