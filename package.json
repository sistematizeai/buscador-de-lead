{
  "name": "leadsync",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source AI-powered GTM automation platform",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "build:api": "pnpm --filter @leadsync/database db:generate && pnpm --filter ./apps/api build",
    "build:web": "pnpm --filter ./apps/web build",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "turbo db:generate",
    "db:push": "turbo db:push",
    "db:migrate": "turbo db:migrate",
    "db:health": "pnpm --filter ./apps/api db:health",
    "db:local:start": "powershell -ExecutionPolicy Bypass -File scripts/start-local-postgres.ps1",
    "db:local:stop": "powershell -ExecutionPolicy Bypass -File scripts/stop-local-postgres.ps1",
    "test:unit": "vitest run",
    "test:e2e": "playwright test --config=playwright.config.ts",
    "test:e2e:ui": "playwright test --config=playwright.config.ts --ui",
    "test:e2e:report": "playwright show-report",
    "deploy:check": "pnpm --filter @leadsync/database db:generate && pnpm --filter ./apps/api lint && pnpm --filter ./apps/web lint && pnpm --filter ./apps/api build && pnpm --filter ./apps/web build"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.48.0",
    "eslint": "^9.39.4",
    "globals": "^17.7.0",
    "prettier": "^3.3.3",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.14.4"
}
