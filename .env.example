# ============================================================
# Prospex - Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# Database (PostgreSQL)
DATABASE_URL="postgresql://prospex:change_me_local_password@localhost:55032/prospex"
# Prisma uses DIRECT_URL for migrations and maintenance scripts.
# In local Docker it can match DATABASE_URL. In Supabase/production, prefer
# the direct database URL when the host is reachable; keep secrets only in backend env files.
DIRECT_URL="postgresql://prospex:change_me_local_password@localhost:55032/prospex"
POSTGRES_USER=prospex
POSTGRES_PASSWORD=change_me_local_password
POSTGRES_DB=prospex

# Redis
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=changeme

# AI Provider (OpenAI or compatible: OpenRouter, Ollama, etc.)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
JWT_SECRET=replace_with_random_32_byte_secret
ENABLE_SWAGGER=false
PASSWORD_RESET_DEV_RESPONSE=false
# Optional: custom base URL for OpenRouter/Ollama
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_BASE_URL=http://localhost:11434/v1

# Individual company search.
COMPANY_CNPJ_PROVIDER_URL=https://brasilapi.com.br/api/cnpj/v1
COMPANY_SEARCH_TIMEOUT_MS=8000

# Scraper provider: gosom is the production-grade Google Maps engine.
SCRAPER_PROVIDER=gosom
GOSOM_BINARY_PATH=tools/bin/gosom-google-maps-scraper.exe
GOSOM_TIMEOUT_MS=120000
GOSOM_DEPTH=1
SCRAPER_QUERY_RETRIES=2
SCRAPER_MAX_ROUNDS=6
SCRAPER_ALLOW_MOCK_FALLBACK=false

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001/api
CORS_ALLOWED_ORIGINS=http://localhost:3000
# Optional for controlled preview domains only. Prefer exact origins above.
# CORS_ALLOWED_HOST_SUFFIXES=buscador-lead.vercel.app

# Production notes
# Vercel frontend only needs NEXT_PUBLIC_API_URL and NEXT_PUBLIC_APP_URL.
# Render backend needs DATABASE_URL, DIRECT_URL, JWT_SECRET, NEXT_PUBLIC_APP_URL,
# NEXT_PUBLIC_API_URL, CORS_ALLOWED_ORIGINS, OPENAI_* and SCRAPER_* variables.
# Never expose OPENAI_API_KEY or JWT_SECRET with NEXT_PUBLIC_.
