# ============================================================
# Prospex - Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# Database (PostgreSQL)
DATABASE_URL="postgresql://prospex:change_me_local_password@localhost:55032/prospex"
POSTGRES_USER=prospex
POSTGRES_PASSWORD=change_me_local_password
POSTGRES_DB=prospex

# Redis
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=changeme

# AI Provider (OpenAI or compatible: OpenRouter, Ollama, etc.)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
JWT_SECRET=replace_with_random_32_byte_secret
# Optional: custom base URL for OpenRouter/Ollama
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_BASE_URL=http://localhost:11434/v1

# Scraper provider: gosom is the production-grade Google Maps engine.
SCRAPER_PROVIDER=gosom
GOSOM_BINARY_PATH=tools/bin/gosom-google-maps-scraper.exe
GOSOM_TIMEOUT_MS=120000
GOSOM_DEPTH=1
SCRAPER_ALLOW_MOCK_FALLBACK=false

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Production only
# HTTP_PORT=80
# HTTPS_PORT=443
